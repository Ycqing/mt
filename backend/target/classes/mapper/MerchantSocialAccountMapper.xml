<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.merchantanalysis.mapper.MerchantSocialAccountMapper">

    <resultMap id="BaseResultMap" type="com.merchantanalysis.entity.MerchantSocialAccount">
        <id column="id" property="id"/>
        <result column="merchant_id" property="merchantId"/>
        <result column="platform" property="platform"/>
        <result column="account_name" property="accountName"/>
        <result column="account_id" property="accountId"/>
        <result column="account_url" property="accountUrl"/>
        <result column="followers_count" property="followersCount"/>
        <result column="following_count" property="followingCount"/>
        <result column="posts_count" property="postsCount"/>
        <result column="verification_status" property="verificationStatus"/>
        <result column="last_fetch_time" property="lastFetchTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectByMerchantId" resultMap="BaseResultMap">
        SELECT * FROM merchant_social_account WHERE merchant_id = #{merchantId} AND deleted = 0
    </select>

    <insert id="batchInsert" parameterType="java.util.List">
        INSERT INTO merchant_social_account (merchant_id, platform, account_name, account_id, account_url,
            followers_count, following_count, posts_count, verification_status, last_fetch_time, create_time, update_time)
        VALUES
        <foreach collection="list" item="item" separator=",">
            (#{item.merchantId}, #{item.platform}, #{item.accountName}, #{item.accountId}, #{item.accountUrl},
            #{item.followersCount}, #{item.followingCount}, #{item.postsCount}, #{item.verificationStatus},
            #{item.lastFetchTime}, NOW(), NOW())
        </foreach>
    </insert>

</mapper>
