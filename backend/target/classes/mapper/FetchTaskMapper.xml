<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.merchantanalysis.mapper.FetchTaskMapper">

    <resultMap id="BaseResultMap" type="com.merchantanalysis.entity.FetchTask">
        <id column="id" property="id"/>
        <result column="task_name" property="taskName"/>
        <result column="merchant_id" property="merchantId"/>
        <result column="task_type" property="taskType"/>
        <result column="task_status" property="taskStatus"/>
        <result column="priority" property="priority"/>
        <result column="source_url" property="sourceUrl"/>
        <result column="params" property="params"/>
        <result column="result" property="result"/>
        <result column="retry_count" property="retryCount"/>
        <result column="execute_time" property="executeTime"/>
        <result column="cost_ms" property="costMs"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="selectPageList" resultMap="BaseResultMap">
        SELECT * FROM fetch_task WHERE deleted = 0
        <if test="taskType != null and taskType != ''">
            AND task_type = #{taskType}
        </if>
        <if test="taskStatus != null and taskStatus != ''">
            AND task_status = #{taskStatus}
        </if>
        ORDER BY create_time DESC
    </select>

</mapper>
